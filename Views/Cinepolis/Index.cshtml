@model IDGS904ASP.Models.Cine

@{
    ViewBag.Title = "Cinepolis";
}

<style>

    body {
        margin: 0;
        padding: 0;
        background: #f5f6fa;
        font-family: "Segoe UI", sans-serif;
    }

    .contenedor {
        width: 400px;
        margin: 70px auto;
        background: white;
        padding: 35px;
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(0,0,0,.08);
        text-align: center;
    }

    .emoji {
        font-size: 42px;
        margin-bottom: 10px;
    }

    h2 {
        color: #2c2c2c;
        margin-bottom: 30px;
    }

    form p {
        text-align: left;
        margin-bottom: 18px;
    }

    input[type=text],
    input[type=number] {
        width: 100%;
        padding: 12px;
        margin-top: 8px;
        border-radius: 10px;
        border: 1px solid #ddd;
        box-sizing: border-box;
    }

    input:focus {
        outline: none;
        border-color: #d32f2f;
    }

    .check {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .boton {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 10px;
        background: #d32f2f;
        color: white;
        cursor: pointer;
        margin-top: 20px;
    }

        .boton:hover {
            background: #b71c1c;
        }

    .error {
        margin-top: 20px;
        padding: 10px;
        background: #ffeaea;
        color: darkred;
        border-radius: 8px;
    }
</style>


<div class="contenedor">

    <div class="emoji">
        🍿🎬
    </div>

    <h2>Compra de boletos</h2>

    <form action="/Cinepolis/Calcular" method="post">

        <p>
            Nombre:
            <input type="text"
                   name="Nombre"
                   placeholder="Ingresa tu nombre" />
        </p>

        <p>
            Cantidad de compradores:
            <input type="number"
                   name="CantidadCompradores" />
        </p>

        <p>
            Cantidad de boletos:
            <input type="number"
                   name="CantidadBoletas"
                   placeholder="Ej. 3" />
        </p>

        <p class="check">
            <input type="checkbox"
                   name="TarjetaCineco" />

            ¿Cuenta con tarjeta CINECO?
        </p>

        <input class="boton"
               type="submit"
               value="Calcular pago" />

    </form>

    @if (ViewBag.Error != null)
    {
        <div class="error">
            @ViewBag.Error
        </div>
    }

</div>